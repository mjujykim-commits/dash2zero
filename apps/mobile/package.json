{
  "name": "@dash2zero/mobile",
  "version": "0.1.0-m2s1",
  "private": true,
  "description": "dash2zero mobile app (React Native + Expo + TypeScript). Korean vocabulary learning, 3-min daily loop.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
