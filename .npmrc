# Expo / React Native 툴링은 pnpm의 strict isolated node_modules를 완전히 지원하지 않는다
# (예: @expo/metro-config가 expo-asset 등 전이 의존을 require.resolve 하지 못해 번들 실패).
# hoisted 링커로 npm 유사 평탄 node_modules를 만들어 Expo prebuild/run/start 호환을 보장한다.
# 참고: https://docs.expo.dev/guides/monorepos/ (pnpm 사용 시 권고)
node-linker=hoisted
# React Native 코드젠은 node_modules/react-native/ReactCommon 등에 파일을 cp로 덮어쓴다.
# pnpm 기본(하드링크)은 store 파일이 읽기전용이라 "Permission denied"로 실패 → 복사 방식으로 강제.
package-import-method=copy
