{
  "name": "dash2zero-monorepo",
  "version": "0.1.0-m2s1",
  "private": true,
  "description": "dash2zero — Korean vocabulary learning app for English-speaking beginners. Monorepo (pnpm workspaces).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "lint": "pnpm -r lint",
    "type-check": "pnpm -r type-check",
    "test": "pnpm -r test",
    "eval": "tsx scripts/eval/runner.ts",
    "eval:srs": "tsx scripts/eval/runner.ts --category=srs",
    "eval:payment": "tsx scripts/eval/runner.ts --category=payment",
    "eval:privacy": "tsx scripts/eval/runner.ts --category=privacy",
    "eval:content": "tsx scripts/eval/runner.ts --category=content",
    "eval:rls": "tsx scripts/eval/runner.ts --category=rls",
    "test:seed": "tsx scripts/seed/__tests__/determinism.test.ts",
    "baseline:check": "tsx scripts/baseline/check-thresholds.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "react-native-screens": "3.31.1",
      "react-native-safe-area-context": "4.10.5",
      "expo-linking": "6.3.1",
      "expo-build-properties": "0.12.5"
    }
  },
  "devDependencies": {
    "tsx": "^4.22.1",
    "yaml": "^2.9.0"
  }
}
